# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production

# ── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Azure SQL Server ──────────────────────────────────────────────────────────
# Format: Driver={ODBC Driver 18 for SQL Server};Server=tcp:<server>.database.windows.net,1433;
#         Database=<db-name>;Uid=<admin-user>;Pwd=<password>;
#         Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;
AZURE_SQL_CONN_STR=

# ── Azure Blob Storage ────────────────────────────────────────────────────────
# Get from: Azure Portal → Storage Account → Access keys → Connection string
AZURE_STORAGE_CONN_STR=
AZURE_BLOB_CONTAINER=retail-data
